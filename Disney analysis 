   "source": [
    "# Parse dates\n",
    "wait_df['WORK_DATE'] = pd.to_datetime(wait_df['WORK_DATE'])\n",
    "wait_df['DEB_TIME'] = pd.to_datetime(wait_df['DEB_TIME'])\n",
    "\n",
    "# Extract time features\n",
    "wait_df['year'] = wait_df['WORK_DATE'].dt.year\n",
    "wait_df['month'] = wait_df['WORK_DATE'].dt.month\n",
    "wait_df['day_of_week'] = wait_df['WORK_DATE'].dt.day_name()\n",
    "wait_df['hour'] = wait_df['DEB_TIME_HOUR']\n",
    "\n",
    "# Rename for clarity\n",
    "wait_df.rename(columns={\n",
    "    'ENTITY_DESCRIPTION_SHORT': 'ride',\n",
    "    'WAIT_TIME_MAX': 'wait_time',\n",
    "    'GUEST_CARRIED': 'guests',\n",
    "    'CAPACITY': 'capacity'\n",
    "}, inplace=True)\n",
    "\n",
    "# Drop nulls in key columns\n",
    "wait_df.dropna(subset=['ride', 'wait_time'], inplace=True)\n",
    "\n",
    "# Remove negative wait times\n",
    "wait_df = wait_df[wait_df['wait_time'] >= 0]\n",
    "\n",
    "print(f\"Clean dataset: {wait_df.shape}\")\n",
    "print(f\"\\nRides: {wait_df['ride'].nunique()}\")\n",
    "print(f\"Date range: {wait_df['WORK_DATE'].min()} → {wait_df['WORK_DATE'].max()}\")\n",
    "print(\"\\nCleaning done ✅\")"
   ]
